# Datenbank (Supabase Connection Pooler — Transaction Mode für Serverless)
# URL aus Supabase Dashboard: Project Settings > Database > Connection Pooler (Transaction mode)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Direktverbindung für drizzle-kit Migrationen (kein PgBouncer — Port 5432)
# URL aus Supabase Dashboard: Project Settings > Database > Connection string (URI)
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase — Werte aus Supabase Dashboard: Project Settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
# ACHTUNG: Service Role Key umgeht RLS vollständig — NIEMALS client-seitig verwenden, nur serverseitig
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Inngest (Job Queue)
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
# PFLICHT EU-Compliance: Daten dürfen die EU nicht verlassen
INNGEST_BASE_URL=https://eu.inngest.com

# KI-Provider
ANTHROPIC_API_KEY=your-anthropic-api-key

# E-Mail
RESEND_API_KEY=your-resend-api-key

# Sicherheit
# HMAC-Secret für signierte Feedback-Links (min. 32 Zeichen, zufällig generiert)
# Generieren: openssl rand -hex 32
HMAC_SECRET=your-hmac-secret-min-32-chars
